# Burnbar signing & notarization environment variables
# Copy relevant values into your shell (or a .env file loaded by your tooling)
# before running `pnpm dist:mac`.  See docs/signing-runbook.md for full steps.
#
# NEVER commit real values — keep secrets outside the repo.

# ── Signing ──────────────────────────────────────────────────────────────────
# Option A: path to an exported Developer ID Application .p12 file
CSC_LINK=/path/to/DeveloperID-Application.p12
CSC_KEY_PASSWORD=your-p12-export-password

# Option B: identity already in the login keychain (use one or the other)
# CSC_NAME=Developer ID Application: Your Name (TEAMID)

# ── Notarization ─────────────────────────────────────────────────────────────
# App-specific password from appleid.apple.com (not your Apple ID password)
APPLE_ID=you@example.com
APPLE_APP_SPECIFIC_PASSWORD=abcd-efgh-ijkl-mnop
APPLE_TEAM_ID=YOURTEAMID
