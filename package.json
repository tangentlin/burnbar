{
  "name": "burnbar",
  "version": "0.1.0",
  "description": "macOS menu bar app that shows your Claude Code token burn and cost in real time, powered by ccusage. Backend-agnostic — works with Anthropic, Vertex AI, and Bedrock.",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "electron .",
    "dev": "tsc && electron .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "dist": "pnpm build && electron-builder",
    "dist:mac": "pnpm build && electron-builder --mac",
    "dist:mac:universal": "pnpm build && electron-builder --mac --universal"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ccusage",
    "menubar",
    "electron",
    "macos",
    "usage",
    "cost"
  ],
  "author": "tangentlin",
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "electron"]
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "22.15.29",
    "electron": "36.4.0",
    "electron-builder": "26.0.12",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "ccusage": "20.0.14"
  },
  "build": {
    "appId": "com.tangentlin.burnbar",
    "productName": "Burnbar",
    "directories": {
      "output": "release"
    },
    "files": ["dist/**/*", "assets/**/*", "node_modules/**/*", "package.json"],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icons/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "identity": null,
      "notarize": false,
      "extendInfo": {
        "LSUIElement": true
      },
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    }
  }
}
