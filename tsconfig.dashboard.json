{
  // Type-checks the browser-context renderer, which the main Node16 config
  // excludes. esbuild does the actual transpile/bundle; this exists purely so
  // `tsc --noEmit` covers the dashboard code (DOM + Chart.js types).
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "lib": ["es2022", "dom", "dom.iterable"],
    "types": []
  },
  "include": ["src/dashboard"],
  "exclude": []
}
